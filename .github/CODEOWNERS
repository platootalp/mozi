# CODEOWNERS - 定义代码审查权限
# 格式: <pattern> <owner1> <owner2> ...
# 匹配规则: 后面的规则覆盖前面的规则

# 默认所有者（所有文件）
* @mozi-team/maintainers

# ============================================
# 敏感配置（需要 2 位 Maintainer 审查）
# ============================================

# CI/CD 配置
/.github/workflows/ @mozi-team/owners @mozi-team/maintainers
/.github/CODEOWNERS @mozi-team/owners

# Mozi 核心配置
/.mozi/mcp.json @mozi-team/owners @mozi-team/maintainers
/.mozi/tools.json @mozi-team/owners @mozi-team/maintainers
/.mozi/config.json @mozi-team/owners @mozi-team/maintainers

# 安全相关
/.mozi/rules/security.md @mozi-team/owners @mozi-team/maintainers

# 依赖管理
/requirements*.txt @mozi-team/maintainers
/package.json @mozi-team/maintainers
/package-lock.json @mozi-team/maintainers

# ============================================
# 核心代码（需要 Maintainer 审查）
# ============================================

/src/mozi/core/ @mozi-team/maintainers
/src/mozi/orchestrator/ @mozi-team/maintainers
/src/mozi/capabilities/tools/ @mozi-team/maintainers

# ============================================
# 文档（任意 Contributor 可审查）
# ============================================

/docs/ @mozi-team/maintainers @mozi-team/contributors
/.mozi/rules/*.md @mozi-team/maintainers @mozi-team/contributors
*.md @mozi-team/maintainers @mozi-team/contributors

# ============================================
# 测试（任意 Contributor 可审查）
# ============================================

/tests/ @mozi-team/maintainers @mozi-team/contributors
